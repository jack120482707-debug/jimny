  "cases": [
    {
      "symptom": "冷車啟動無力",
      "severity": "medium",
      "possible_causes": [
        "電瓶電壓不足",
        "電瓶端子鬆動或氧化",
        "發電機充電不足",
        "啟動馬達老化"
      ],
      "diagnostic_steps": [
        "量測熄火電壓，健康值通常約 12.6V 左右。",
        "啟動時觀察電壓是否大幅下掉。",
        "發動後量測充電電壓。",
        "檢查正負極端子與接地線。"
      ],
      "recommended_actions": [
        "清潔並固定電瓶端子。",
        "電瓶健康度不足時更換。",
        "若充電電壓異常，檢查發電機與皮帶。"
      ],
      "related_obd_codes": []
    },
    {
      "symptom": "行駛中方向盤抖動",
      "severity": "high",
      "possible_causes": [
        "輪胎平衡不良",
        "輪胎變形或磨耗不均",
        "定位角度異常",
        "轉向拉桿或和尚頭間隙",
        "前軸或輪轂軸承間隙"
      ],
      "diagnostic_steps": [
        "記錄抖動發生速度區間。",
        "檢查胎壓與輪胎外觀。",
        "做輪胎平衡與前後輪對調測試。",
        "頂車檢查輪轂、轉向拉桿與懸吊間隙。"
      ],
      "recommended_actions": [
        "重新平衡輪胎。",
        "磨耗異常時做四輪定位。",
        "若有間隙，更換相關底盤零件。"
      ],
      "related_obd_codes": []
    },
    {
      "symptom": "水溫偏高",
      "severity": "critical",
      "possible_causes": [
        "冷卻液不足",
        "水箱或水管滲漏",
        "節溫器故障",
        "水箱風扇不作動",
        "水泵浦效率下降"
      ],
      "diagnostic_steps": [
        "安全停車並避免立即打開熱水箱蓋。",
        "冷車後檢查副水箱與水箱液面。",
        "檢查水管、水箱、水泵浦是否有滲漏痕跡。",
        "怠速觀察風扇是否啟動。"
      ],
      "recommended_actions": [
        "補充正確規格冷卻液。",
        "修復滲漏點後排氣。",
        "若持續過熱，拖吊檢修，避免引擎受損。"
      ],
      "related_obd_codes": [
        "P0115",
        "P0128"
      ]
    },
    {
      "symptom": "4WD 切換後異音",
      "severity": "medium",
      "possible_causes": [
        "在高抓地鋪裝路面使用 4H 或 4L",
        "分動箱油品老化",
        "傳動軸十字接頭磨耗",
        "前輪轂或前差速器異常"
      ],
      "diagnostic_steps": [
        "確認使用場景是否適合 4WD。",
        "在低速直線測試 2H、4H、4L 差異。",
        "檢查分動箱與差速器油位。",
        "檢查傳動軸間隙與十字接頭。"
      ],
      "recommended_actions": [
        "避免在乾燥柏油路長時間使用 4WD。",
        "更換分動箱與差速器油。",
        "若異音持續，檢查傳動系統。"
      ],
      "related_obd_codes": []
    },
    {
      "symptom": "Check Engine 燈亮",
      "severity": "medium",
      "possible_causes": [
        "感知器訊號異常",
        "燃油蒸發系統洩漏",
        "點火或燃油修正異常",
        "排放系統效率不足"
      ],
      "diagnostic_steps": [
        "使用 OBD-II 讀取故障碼與 freeze frame。",
        "確認油箱蓋是否鎖緊。",
        "檢查是否伴隨抖動、熄火或油耗異常。",
        "清除故障碼前先記錄完整資料。"
